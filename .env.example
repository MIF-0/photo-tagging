# =====================================================================
# Provider selection
# =====================================================================
# Which vision LLM to use: "gemini" (default) or "groq".
PROVIDER=gemini

# =====================================================================
# Gemini  (used when PROVIDER=gemini)
# =====================================================================
GEMINI_API_KEY=your_gemini_key_here
# Delay between API calls in milliseconds.
GEMINI_RATE_LIMIT_MS=2000
# Optional. Default: gemini-2.5-flash-lite (highest free-tier daily quota).
# Other options: gemini-2.5-flash, gemini-2.5-pro, gemini-3-flash-preview, ...
GEMINI_MODEL=gemini-2.5-flash-lite

# =====================================================================
# Groq  (used when PROVIDER=groq)
# =====================================================================
GROQ_API_KEY=your_groq_key_here
GROQ_RATE_LIMIT_MS=2000
# Optional. Default: meta-llama/llama-4-scout-17b-16e-instruct.
# See https://console.groq.com/docs/models for the current vision-capable list.
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# =====================================================================
# Logging
# =====================================================================
# Optional. Defaults to ./photo_tagger.log in the current working directory.
# The file is truncated on each run.
LOG_FILE=photo_tagger.log

# =====================================================================
# Stock-site extras (Pond5 etc.)
# =====================================================================
# Country is written to IPTC, XMP-photoshop, and XMP-iptcExt schemas.
# Defaults to "United Kingdom".
DEFAULT_COUNTRY=United Kingdom

# Camera make/model are only written if the source JPEG has no EXIF Make/Model
# yet — genuine camera EXIF is never overwritten.
# Defaults: Panasonic / DC-S5M2X (Lumix S5IIx).
DEFAULT_CAMERA_MAKE=Panasonic
DEFAULT_CAMERA_MODEL=DC-S5M2X
